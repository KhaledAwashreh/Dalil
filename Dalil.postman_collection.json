{
	"info": {
		"name": "Dalil API",
		"description": "Complete testing collection for the Dalil consulting memory system API. All 18 endpoints documented.",
		"schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
	},
	"variable": [
		{
			"key": "base_url",
			"value": "http://localhost:8000"
		},
		{
			"key": "vault",
			"value": "default"
		},
		{
			"key": "case_id",
			"value": "case-123"
		},
		{
			"key": "entity_name",
			"value": "digital-transformation"
		},
		{
			"key": "request_id",
			"value": "req-123"
		}
	],
	"item": [
		{
			"name": "Health & Status",
			"item": [
				{
					"name": "Health Check",
					"request": {
						"method": "GET",
						"header": [],
						"url": {
							"raw": "{{base_url}}/health",
							"host": ["localhost"],
							"port": "8000",
							"path": ["health"]
						},
						"description": "Check API health, MuninnDB connectivity, and LLM status.\n\nResponse fields: status, muninn_connected, llm_provider, llm_model."
					},
					"response": []
				},
				{
					"name": "Vault Statistics",
					"request": {
						"method": "GET",
						"header": [],
						"url": {
							"raw": "{{base_url}}/vault/stats?vault={{vault}}",
							"host": ["localhost"],
							"port": "8000",
							"path": ["vault", "stats"],
							"query": [
								{
									"key": "vault",
									"value": "{{vault}}"
								}
							]
						},
						"description": "Get vault health metrics from MuninnDB.\n\nResponse fields: vault, total_memories, health, enrichment_mode, contradiction_count, contradictions."
					},
					"response": []
				},
				{
					"name": "Recent Memories",
					"request": {
						"method": "GET",
						"header": [],
						"url": {
							"raw": "{{base_url}}/session/recent?vault={{vault}}&limit=10",
							"host": ["localhost"],
							"port": "8000",
							"path": ["session", "recent"],
							"query": [
								{
									"key": "vault",
									"value": "{{vault}}"
								},
								{
									"key": "limit",
									"value": "10"
								}
							]
						},
						"description": "Get recent memory activity (writes and activations) from the last 24 hours via muninn_session."
					},
					"response": []
				}
			]
		},
		{
			"name": "Consulting",
			"item": [
				{
					"name": "Consult — Basic",
					"request": {
						"method": "POST",
						"header": [
							{
								"key": "Content-Type",
								"value": "application/json"
							}
						],
						"body": {
							"mode": "raw",
							"raw": "{\n  \"problem\": \"How should we approach a digital transformation for a mid-size retail company?\"\n}"
						},
						"url": {
							"raw": "{{base_url}}/consult",
							"host": ["localhost"],
							"port": "8000",
							"path": ["consult"]
						},
						"description": "Submit a basic consulting query with just a problem statement. Uses default vault."
					},
					"response": []
				},
				{
					"name": "Consult — With Context and Tags",
					"request": {
						"method": "POST",
						"header": [
							{
								"key": "Content-Type",
								"value": "application/json"
							}
						],
						"body": {
							"mode": "raw",
							"raw": "{\n  \"problem\": \"What change management strategy works best for ERP migrations?\",\n  \"context\": \"The client is a 500-employee manufacturing firm currently on legacy SAP. Leadership is supportive but middle management is resistant.\",\n  \"tags\": [\"change-management\", \"erp\", \"manufacturing\"],\n  \"vault\": \"{{vault}}\"\n}"
						},
						"url": {
							"raw": "{{base_url}}/consult",
							"host": ["localhost"],
							"port": "8000",
							"path": ["consult"]
						},
						"description": "Submit a consulting query with full context, tags, and vault specification. Returns matching cases and LLM synthesis."
					},
					"response": []
				},
				{
					"name": "Provide Feedback (Legacy)",
					"request": {
						"method": "POST",
						"header": [
							{
								"key": "Content-Type",
								"value": "application/json"
							}
						],
						"body": {
							"mode": "raw",
							"raw": "{\n  \"request_id\": \"{{request_id}}\",\n  \"signal\": \"useful\",\n  \"case_ids\": [\"case-1\", \"case-2\"]\n}"
						},
						"url": {
							"raw": "{{base_url}}/feedback",
							"host": ["localhost"],
							"port": "8000",
							"path": ["feedback"]
						},
						"description": "Provide feedback on consultation results. Legacy format uses signal ('useful'/'not_useful') + case_ids."
					},
					"response": []
				},
				{
					"name": "Provide Feedback (Per-Case)",
					"request": {
						"method": "POST",
						"header": [
							{
								"key": "Content-Type",
								"value": "application/json"
							}
						],
						"body": {
							"mode": "raw",
							"raw": "{\n  \"request_id\": \"{{request_id}}\",\n  \"results\": [\n    {\"case_id\": \"case-1\", \"relevant\": true},\n    {\"case_id\": \"case-2\", \"relevant\": false}\n  ],\n  \"comment\": \"First case was exactly what I needed\"\n}"
						},
						"url": {
							"raw": "{{base_url}}/feedback",
							"host": ["localhost"],
							"port": "8000",
							"path": ["feedback"]
						},
						"description": "Provide granular per-case feedback. Preferred format with explicit relevance for each case. Triggers muninn_feedback for SGD weight tuning and muninn_link for co-relevant cases."
					},
					"response": []
				}
			]
		},
		{
			"name": "Ingestion — CSV",
			"item": [
				{
					"name": "Ingest CSV (server path)",
					"request": {
						"method": "POST",
						"header": [
							{
								"key": "Content-Type",
								"value": "application/json"
							}
						],
						"body": {
							"mode": "raw",
							"raw": "{\n  \"file_path\": \"/path/to/your/cases.csv\",\n  \"vault\": \"{{vault}}\",\n  \"tags\": [\"imported\"]\n}"
						},
						"url": {
							"raw": "{{base_url}}/ingest/csv",
							"host": ["localhost"],
							"port": "8000",
							"path": ["ingest", "csv"]
						},
						"description": "Ingest a CSV file by server-side path. CSV must have at least 'title' and 'content' columns."
					},
					"response": []
				},
				{
					"name": "Ingest CSV (file upload)",
					"request": {
						"method": "POST",
						"header": [],
						"body": {
							"mode": "formdata",
							"formdata": [
								{
									"key": "file",
									"type": "file",
									"src": "",
									"description": "Select a CSV file to upload"
								},
								{
									"key": "vault",
									"value": "default",
									"type": "text"
								},
								{
									"key": "tags",
									"value": "imported,csv",
									"type": "text",
									"description": "Comma-separated tags"
								}
							]
						},
						"url": {
							"raw": "{{base_url}}/ingest/csv/upload",
							"host": ["localhost"],
							"port": "8000",
							"path": ["ingest", "csv", "upload"]
						},
						"description": "Upload a CSV file directly. CSV must have at least 'title' and 'content' columns."
					},
					"response": []
				}
			]
		},
		{
			"name": "Ingestion — PDF",
			"item": [
				{
					"name": "Ingest PDF (server path)",
					"request": {
						"method": "POST",
						"header": [
							{
								"key": "Content-Type",
								"value": "application/json"
							}
						],
						"body": {
							"mode": "raw",
							"raw": "{\n  \"file_path\": \"/path/to/your/document.pdf\",\n  \"vault\": \"{{vault}}\",\n  \"tags\": [\"imported\"]\n}"
						},
						"url": {
							"raw": "{{base_url}}/ingest/pdf",
							"host": ["localhost"],
							"port": "8000",
							"path": ["ingest", "pdf"]
						},
						"description": "Ingest a PDF file by server-side path. PDF will be chunked automatically."
					},
					"response": []
				},
				{
					"name": "Ingest PDF (file upload)",
					"request": {
						"method": "POST",
						"header": [],
						"body": {
							"mode": "formdata",
							"formdata": [
								{
									"key": "file",
									"type": "file",
									"src": "",
									"description": "Select a PDF file to upload"
								},
								{
									"key": "vault",
									"value": "default",
									"type": "text"
								},
								{
									"key": "tags",
									"value": "imported,pdf",
									"type": "text",
									"description": "Comma-separated tags"
								}
							]
						},
						"url": {
							"raw": "{{base_url}}/ingest/pdf/upload",
							"host": ["localhost"],
							"port": "8000",
							"path": ["ingest", "pdf", "upload"]
						},
						"description": "Upload a PDF file directly. PDF will be chunked automatically."
					},
					"response": []
				}
			]
		},
		{
			"name": "Ingestion — Confluence",
			"item": [
				{
					"name": "Ingest Confluence Page (by URL)",
					"request": {
						"method": "POST",
						"header": [
							{
								"key": "Content-Type",
								"value": "application/json"
							}
						],
						"body": {
							"mode": "raw",
							"raw": "{\n  \"url\": \"https://yourorg.atlassian.net/wiki/spaces/TEAM/pages/123456/Page+Title\",\n  \"vault\": \"{{vault}}\",\n  \"tags\": [\"confluence\"]\n}"
						},
						"url": {
							"raw": "{{base_url}}/ingest/confluence",
							"host": ["localhost"],
							"port": "8000",
							"path": ["ingest", "confluence"]
						},
						"description": "Ingest a single Confluence page by its full URL."
					},
					"response": []
				},
				{
					"name": "Ingest Confluence Page (by ID)",
					"request": {
						"method": "POST",
						"header": [
							{
								"key": "Content-Type",
								"value": "application/json"
							}
						],
						"body": {
							"mode": "raw",
							"raw": "{\n  \"page_id\": \"123456\",\n  \"vault\": \"{{vault}}\",\n  \"tags\": [\"confluence\"]\n}"
						},
						"url": {
							"raw": "{{base_url}}/ingest/confluence",
							"host": ["localhost"],
							"port": "8000",
							"path": ["ingest", "confluence"]
						},
						"description": "Ingest a single Confluence page by its page ID."
					},
					"response": []
				},
				{
					"name": "Ingest Confluence Space",
					"request": {
						"method": "POST",
						"header": [
							{
								"key": "Content-Type",
								"value": "application/json"
							}
						],
						"body": {
							"mode": "raw",
							"raw": "{\n  \"space_key\": \"TEAM\",\n  \"vault\": \"{{vault}}\",\n  \"limit\": 25,\n  \"tags\": [\"confluence\", \"bulk\"]\n}"
						},
						"url": {
							"raw": "{{base_url}}/ingest/confluence",
							"host": ["localhost"],
							"port": "8000",
							"path": ["ingest", "confluence"]
						},
						"description": "Ingest all pages from a Confluence space (up to the limit). Requires confluence_base_url, confluence_token, and confluence_email in config."
					},
					"response": []
				}
			]
		},
		{
			"name": "Case Management",
			"item": [
				{
					"name": "Evolve Case",
					"request": {
						"method": "PUT",
						"header": [
							{
								"key": "Content-Type",
								"value": "application/json"
							}
						],
						"body": {
							"mode": "raw",
							"raw": "{\n  \"case_id\": \"{{case_id}}\",\n  \"content\": \"Updated content with new insights from recent engagement\",\n  \"concept\": \"Reason for the update\",\n  \"vault\": \"{{vault}}\"\n}"
						},
						"url": {
							"raw": "{{base_url}}/cases/{{case_id}}",
							"host": ["localhost"],
							"port": "8000",
							"path": ["cases", "{{case_id}}"]
						},
						"description": "Update/evolve an existing case via muninn_evolve. Archives previous version. Requires content (new_content) and concept (used as reason)."
					},
					"response": []
				},
				{
					"name": "Set Case State",
					"request": {
						"method": "PATCH",
						"header": [
							{
								"key": "Content-Type",
								"value": "application/json"
							}
						],
						"body": {
							"mode": "raw",
							"raw": "{\n  \"case_id\": \"{{case_id}}\",\n  \"state\": \"archived\",\n  \"vault\": \"{{vault}}\"\n}"
						},
						"url": {
							"raw": "{{base_url}}/cases/{{case_id}}/state",
							"host": ["localhost"],
							"port": "8000",
							"path": ["cases", "{{case_id}}", "state"]
						},
						"description": "Set the lifecycle state of a case via muninn_state. Valid states: planning, active, paused, blocked, completed, cancelled, archived, soft_deleted."
					},
					"response": []
				},
				{
					"name": "Consolidate Cases",
					"request": {
						"method": "POST",
						"header": [
							{
								"key": "Content-Type",
								"value": "application/json"
							}
						],
						"body": {
							"mode": "raw",
							"raw": "{\n  \"case_ids\": [\"case-1\", \"case-2\", \"case-3\"],\n  \"concept\": \"Merged: Common pattern across related cases\",\n  \"vault\": \"{{vault}}\"\n}"
						},
						"url": {
							"raw": "{{base_url}}/cases/consolidate",
							"host": ["localhost"],
							"port": "8000",
							"path": ["cases", "consolidate"]
						},
						"description": "Merge multiple related cases into a single consolidated case via muninn_consolidate. Requires at least 2 case_ids."
					},
					"response": []
				}
			]
		},
		{
			"name": "Entity Management",
			"item": [
				{
					"name": "List Entities",
					"request": {
						"method": "GET",
						"header": [],
						"url": {
							"raw": "{{base_url}}/vault/entities?vault={{vault}}",
							"host": ["localhost"],
							"port": "8000",
							"path": ["vault", "entities"],
							"query": [
								{
									"key": "vault",
									"value": "{{vault}}"
								}
							]
						},
						"description": "List all entities in a vault's entity graph via muninn_entities."
					},
					"response": []
				},
				{
					"name": "Entity Details",
					"request": {
						"method": "GET",
						"header": [],
						"url": {
							"raw": "{{base_url}}/vault/entities/{{entity_name}}?vault={{vault}}",
							"host": ["localhost"],
							"port": "8000",
							"path": ["vault", "entities", "{{entity_name}}"],
							"query": [
								{
									"key": "vault",
									"value": "{{vault}}"
								}
							]
						},
						"description": "Get details for a specific entity via muninn_entity. Returns 404 if entity not found."
					},
					"response": []
				},
				{
					"name": "Entity Timeline",
					"request": {
						"method": "GET",
						"header": [],
						"url": {
							"raw": "{{base_url}}/vault/entities/{{entity_name}}/timeline?vault={{vault}}",
							"host": ["localhost"],
							"port": "8000",
							"path": ["vault", "entities", "{{entity_name}}", "timeline"],
							"query": [
								{
									"key": "vault",
									"value": "{{vault}}"
								}
							]
						},
						"description": "Get temporal history of an entity via muninn_entity_timeline."
					},
					"response": []
				},
				{
					"name": "Entity Cases",
					"request": {
						"method": "GET",
						"header": [],
						"url": {
							"raw": "{{base_url}}/vault/entities/{{entity_name}}/cases?vault={{vault}}",
							"host": ["localhost"],
							"port": "8000",
							"path": ["vault", "entities", "{{entity_name}}", "cases"],
							"query": [
								{
									"key": "vault",
									"value": "{{vault}}"
								}
							]
						},
						"description": "Find all cases/engrams linked to an entity via muninn_find_by_entity."
					},
					"response": []
				}
			]
		},
		{
			"name": "Graph Traversal",
			"item": [
				{
					"name": "Traverse Graph",
					"request": {
						"method": "POST",
						"header": [
							{
								"key": "Content-Type",
								"value": "application/json"
							}
						],
						"body": {
							"mode": "raw",
							"raw": "{\n  \"start_id\": \"engram-id-here\",\n  \"max_depth\": 3,\n  \"relation_filter\": [\"supports\", \"contradicts\"],\n  \"vault\": \"{{vault}}\"\n}"
						},
						"url": {
							"raw": "{{base_url}}/traverse",
							"host": ["localhost"],
							"port": "8000",
							"path": ["traverse"]
						},
						"description": "BFS graph traversal from a starting engram via muninn_traverse. Returns nodes, edges, and total reachable count."
					},
					"response": []
				}
			]
		}
	]
}
